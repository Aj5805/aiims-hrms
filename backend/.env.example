# AIIMS HRMS environment variables
# Copy this file to .env and fill in the values.

APP_ENV=development

# Database
DATABASE_URL=postgresql+asyncpg://aiims_hrms:aiims_hrms@localhost:5432/aiims_hrms
DATABASE_URL_SYNC=postgresql+psycopg2://aiims_hrms:aiims_hrms@localhost:5432/aiims_hrms
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_PRE_PING=True

# Auth
# For local development this placeholder is accepted.
# For staging/production you must replace it with a strong secret of at least 32 characters.
JWT_SECRET=local-dev-insecure-secret-change-before-shared-use
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=False
# MUST be True in any HTTPS/production deployment

# CORS
# Use an explicit comma-separated allowlist. Only local/test should ever use "*".
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email (Zoho SMTP)
ZOHO_SMTP_HOST=smtp.zoho.in
ZOHO_SMTP_PORT=587
ZOHO_EMAIL=
ZOHO_APP_PASSWORD=

# Rate limiting
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_GENERAL=100/minute
RATE_LIMIT_EXPORT=10/minute

# Upload
UPLOAD_MAX_SIZE_MB=5
UPLOAD_DIR=uploads

# Bcrypt
BCRYPT_ROUNDS=12
